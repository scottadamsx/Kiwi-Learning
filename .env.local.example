# Copy to .env.local and fill in.
# Get a key at https://platform.claude.com/ → API Keys.
# (If you've run `ant auth login`, the SDK picks up that profile and this can stay empty.)
ANTHROPIC_API_KEY=

# Model used for all generation and grading. Default: claude-opus-4-8.
# KIWI_MODEL=claude-opus-4-8

# Number of independent grading samples for free-text answers (uncertainty flagging).
# KIWI_GRADER_SAMPLES=3
