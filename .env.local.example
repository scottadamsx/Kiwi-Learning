# All optional. With nothing set, Kiwi uses your Claude Code login (run
# `claude`, then /login) — no API key needed.

# Direct API access instead of the Claude Code subscription:
# ANTHROPIC_API_KEY=

# Force a provider: api | claude-code (default: auto — API key wins if present)
# KIWI_PROVIDER=

# Model tiers (defaults shown for the Claude Code path):
# KIWI_MODEL_PLAN=claude-fable-5        # outline mapping + assignment tutor
# KIWI_MODEL_CONTENT=                   # lessons/cards/quizzes (empty = your Claude Code default)
# KIWI_MODEL_FAST=claude-sonnet-4-6     # grading + notebook chat
# KIWI_MODEL=                           # set to pin EVERY tier to one model

# Max grading samples for borderline free-text answers (adaptive; default 3).
# KIWI_GRADER_SAMPLES=3
